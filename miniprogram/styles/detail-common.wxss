.detail-page {
  min-height: 100vh;
  background: #0b0320;
  color: #fff;
  box-sizing: border-box;
}

.detail-body {
  padding: 0 12px 18px;
  box-sizing: border-box;
}

.detail-card {
  background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.015));
  border-radius: 16px;
  box-shadow: 0 10px 24px rgba(11,3,32,0.24);
  overflow: hidden;
}

.detail-heading {
  margin-top: 12px;
  font-size: 20px;
  line-height: 1.3;
  font-weight: 700;
  text-align: center;
  color: #ffd6ff;
}