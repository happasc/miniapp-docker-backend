@import "../../styles/detail-common.wxss";

.page{min-height:100vh}
.account-card{margin-top:12px;background:linear-gradient(180deg,rgba(255,255,255,0.03),rgba(255,255,255,0.015));border-radius:16px;padding:14px;display:flex;align-items:center;box-shadow:0 10px 24px rgba(11,3,32,0.24)}
.account-avatar{width:56px;height:56px;border-radius:12px;background:#6b21a8;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;margin-right:12px}
.account-info{flex:1}
.account-name{color:#fff;font-size:15px;font-weight:700}
.account-id{margin-top:6px;color:rgba(230,217,255,0.78);font-size:12px}

/* 个人信息修改模块 */
.edit-profile-card{margin-top:16px;background:linear-gradient(180deg,rgba(255,255,255,0.03),rgba(255,255,255,0.015));border-radius:16px;padding:16px 14px;box-shadow:0 10px 24px rgba(11,3,32,0.24)}
.edit-title{color:rgba(230,217,255,0.55);font-size:13px;margin-bottom:12px;}
.edit-item{display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid rgba(255,255,255,0.06)}
.edit-item:last-child{border-bottom:none}
.edit-label{color:#fff;font-size:15px}
.avatar-wrapper{padding:0 !important;margin:0 !important;background:transparent !important;border:none !important;width:56px !important;height:56px !important;border-radius:50% !important;overflow:hidden;}
.avatar-wrapper::after{border:none !important;}
.edit-avatar{width:56px;height:56px;border-radius:50%;background:#333;display:block;}
.nickname-input{flex:1;text-align:right;color:#fff;font-size:15px;margin-left:16px;padding-right:0;border:none;background:transparent;}

.gender-radio-group{display:flex;gap:16px;}
.gender-label{display:flex;align-items:center;color:#fff;font-size:15px;cursor:pointer;}
.gender-label radio{transform:scale(0.8);margin-right:4px;}

/* 性别只读状态样式 */
.gender-readonly{display:flex;align-items:center;gap:8px;}
.gender-text{color:#8b5cf6;font-size:15px;font-weight:600;}
.gender-hint{color:rgba(230,217,255,0.5);font-size:12px;}

/* 自定义性别确认模态框 */
.gender-modal-overlay{
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.gender-modal{
  width: 600rpx;
  background: linear-gradient(135deg, #1a0b2e 0%, #0b0320 100%);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(139, 92, 246, 0.3);
  border: 2rpx solid rgba(139, 92, 246, 0.3);
}

.modal-header{
  padding: 40rpx 32rpx 24rpx;
  text-align: center;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.modal-title{
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

.modal-body{
  padding: 40rpx 32rpx;
}

.gender-highlight{
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.gender-label-text{
  font-size: 28rpx;
  color: rgba(230, 217, 255, 0.8);
  margin-bottom: 16rpx;
}

.gender-value{
  font-size: 56rpx;
  font-weight: 800;
  color: #8b5cf6;
  text-shadow: 0 4rpx 12rpx rgba(139, 92, 246, 0.4);
}

.modal-divider{
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(139, 92, 246, 0.5), transparent);
  margin: 24rpx 0;
}

.modal-warning{
  font-size: 26rpx;
  color: rgba(230, 217, 255, 0.7);
  line-height: 1.8;
  text-align: center;
}

.modal-footer{
  display: flex;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.modal-btn{
  flex: 1;
  padding: 32rpx 0;
  text-align: center;
  cursor: pointer;
  transition: all 0.3s;
}

.modal-btn:active{
  opacity: 0.7;
}

.btn-text{
  font-size: 32rpx;
  font-weight: 600;
}

.cancel-btn .btn-text{
  color: rgba(230, 217, 255, 0.8);
}

.confirm-btn .btn-text{
  color: #8b5cf6;
  font-weight: 700;
}

.modal-divider-vertical{
  width: 1rpx;
  background: rgba(255, 255, 255, 0.1);
}

.login-btn{margin-top:12px;background:linear-gradient(90deg,#8b5cf6,#6b21a8);color:#fff;border-radius:10px}
.login-tip{margin-top:8px;color:rgba(230,217,255,0.85);font-size:12px}
.login-error{margin-top:8px;color:#ffd2d2;background:rgba(239,68,68,0.2);border:1px solid rgba(248,113,113,0.45);padding:8px 10px;border-radius:8px;font-size:12px;line-height:1.5}
.setting-list{margin-top:16px;background:linear-gradient(180deg,rgba(255,255,255,0.03),rgba(255,255,255,0.015));border-radius:16px;padding:4px 14px;box-shadow:0 10px 24px rgba(11,3,32,0.24)}
.setting-item{display:flex;justify-content:space-between;align-items:center;padding:16px 0;border-bottom:1px solid rgba(255,255,255,0.06)}
.setting-item:last-child{border-bottom:none}
.setting-title{color:#fff;font-size:15px}
.setting-arrow{color:rgba(230,217,255,0.55);font-size:22px;line-height:1}
.logout-item{justify-content:center}
.logout-text{color:#ffb4c4;font-weight:700}