<!--miniprogram/pages/booster-lobby/booster-lobby.wxml-->
<view class="lobby-container">
  <navigation-bar title="极速接单大厅" back="{{true}}"></navigation-bar>
  
  <!-- ✨ 固定区域：统计数据 -->
  <view class="header-stats">
    <view class="stat-item">
      <text class="stat-value">{{todayCount}}</text>
      <text class="stat-label">今日接单</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">￥{{todayIncome}}</text>
      <text class="stat-label">今日收益</text>
    </view>
  </view>

  <!-- ✨ 固定区域：结算收益按钮（点击后发送结算申请卡片给客服） -->
  <button 
    class="settle-btn" 
    bindtap="handleSettleIncome"
    disabled="{{todayIncome <= 0}}"
  >
    {{todayIncome > 0 ? '结算收益' : '暂无收益可结算'}}
  </button>

  <!-- ✨ 可滚动区域：订单列表 -->
  <view class="pool-title">实时订单池 <text class="refresh" bindtap="fetchOrders">刷新</text></view>

  <scroll-view class="order-list" scroll-y>
    <block wx:if="{{orders.length === 0}}">
      <view class="empty-state">
        <text>当前没有可夺取的订单</text>
      </view>
    </block>

    <block wx:else>
      <view class="order-card" wx:for="{{orders}}" wx:key="_id">
        <!-- 调试信息 -->
        <!-- <view style="color: red; font-size: 20rpx;">调试: actualAmount={{item.actualAmount}}, originalAmount={{item.originalAmount}}</view> -->
        
        <!-- 价格显示区域 - 左侧显示 -->
        <view class="price-section-left">
          <view class="price-row">
            <text class="price-value">￥{{item.actualAmount}}</text>
          </view>
        </view>
        
        <view class="card-header">
          <view class="game-tag">{{item.gameName}}</view>
        </view>
        <view class="card-body">
          <view class="req-item">档位说明: {{item.summary}}</view>
          <view class="req-item" wx:if="{{item.extra}}">补充说明: {{item.extra}}</view>
          <view class="time">下单时间: {{item.createTimeFormatted}}</view>
          <view class="time">订单编号: {{item.orderNo}}</view>
        </view>
        <view class="card-footer">
          <button class="grab-btn" data-id="{{item._id}}" bindtap="grabOrder" loading="{{grabLoading === item._id}}">立即抢单</button>
        </view>
      </view>
    </block>
  </scroll-view>

  <!-- ✨ 固定区域：历史收益入口 -->
  <view class="history-entry" bindtap="toggleHistoryList">
    <view class="history-title">
      <text>历史收益</text>
      <text class="history-arrow">{{showHistoryList ? '▼' : '›'}}</text>
    </view>
    <view class="history-stats">
      <view class="history-stat">
        <text class="history-value">{{totalSettlements}}</text>
        <text class="history-label">结算次数</text>
      </view>
      <view class="history-stat">
        <text class="history-value">¥{{totalSettlementAmount}}</text>
        <text class="history-label">累计收益</text>
      </view>
    </view>
  </view>

  <!-- ✨ 可滚动区域：历史收益列表 -->
  <view class="history-list" wx:if="{{showHistoryList}}">
    <block wx:if="{{settlementRecords.length === 0}}">
      <view class="empty-history">
        <text>暂无历史结算记录</text>
      </view>
    </block>
    <block wx:else>
      <view class="history-item" wx:for="{{settlementRecords}}" wx:key="_id">
        <view class="history-item-header">
          <view class="history-date">{{item.settleDate}}</view>
          <view class="history-amount">¥{{item.amount.toFixed(2)}}</view>
        </view>
        <view class="history-item-footer">
          <text class="history-confirm-time">确认时间：{{item.confirmTimeStr}}</text>
          <text class="history-status confirmed">已确认</text>
        </view>
      </view>
    </block>
  </view>
</view>