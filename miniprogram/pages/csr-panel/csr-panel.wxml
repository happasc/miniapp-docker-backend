<navigation-bar title="客服工作台" back="{{true}}" color="#fff" background="linear-gradient(180deg, #0b0320, #1a0a3e)"></navigation-bar>

<view class="container">
  <view class="tab-header">
    <view class="tab-item {{currentTab === 'inquiries' ? 'active' : ''}}" data-tab="inquiries" bindtap="switchTab">普通咨询</view>
    <view class="tab-item {{currentTab === 'refunds' ? 'active' : ''}}" data-tab="refunds" bindtap="switchTab">退款/售后请求</view>
    <view class="tab-item {{currentTab === 'settlements' ? 'active' : ''}}" data-tab="settlements" bindtap="switchTab">收益结算</view>
  </view>

  <view class="list-container">
    <!-- 普通咨询列表 -->
    <block wx:if="{{currentTab === 'inquiries'}}">
      <view class="empty-tip" wx:if="{{!inquiriesList || inquiriesList.length === 0}}">暂无等待回复的咨询</view>
      <view class="room-card" wx:for="{{inquiriesList}}" wx:key="_id" data-targetid="{{item.roomId}}" bindtap="openChat">
        <view class="room-header">
          <view class="user-info">
            <image wx:if="{{item.userAvatar}}" class="user-avatar" src="{{item.userAvatar}}" mode="aspectFill"></image>
            <view wx:else class="user-avatar-placeholder">{{item.userName.charAt(0)}}</view>
            <view class="user-name">{{item.userName}}</view>
          </view>
          <view class="room-time">{{item.updatedAtStr}}</view>
        </view>
        <view class="room-desc">{{item.lastMessage || '暂无内容'}}</view>
        <view class="room-arrow">›</view>
      </view>
    </block>

    <!-- 退款申请列表 -->
    <block wx:if="{{currentTab === 'refunds'}}">
      <view class="empty-tip" wx:if="{{!refundsList || refundsList.length === 0}}">暂无退款申请</view>
      <view class="room-card refund" wx:for="{{refundsList}}" wx:key="roomId" data-targetid="{{item.roomId}}" bindtap="openChat">
        <view class="room-header">
          <view class="user-info">
            <view class="user-avatar-placeholder refund-icon">💰</view>
            <view class="user-name">订单退款申请</view>
          </view>
          <view class="room-time">{{item.updatedAtStr}}</view>
        </view>
        <view class="room-desc" wx:if="{{item.refundInfo && item.refundInfo.orderNo}}">
          <text class="refund-order-no">订单号：{{item.refundInfo.orderNo}}</text>
          <text class="refund-amount">金额：¥{{item.refundInfo.amount}}</text>
        </view>
        <view class="room-desc alert">点击处理此退款申请</view>
        <view class="room-arrow">›</view>
      </view>
    </block>

    <!-- ✨ 新增：结算请求列表 -->
    <block wx:if="{{currentTab === 'settlements'}}">
      <view class="empty-tip" wx:if="{{!settlementsList || settlementsList.length === 0}}">暂无结算申请</view>
      <view class="room-card settlement" wx:for="{{settlementsList}}" wx:key="roomId" data-targetid="{{item.roomId}}" bindtap="openChat">
        <view class="room-header">
          <view class="user-info">
            <view class="user-avatar-placeholder settlement-icon">💵</view>
            <view class="user-name">打手收益结算</view>
          </view>
          <view class="room-time">{{item.updatedAtStr}}</view>
        </view>
        <view class="room-desc" wx:if="{{item.settlementInfo && item.settlementInfo.amount}}">
          <text class="settlement-amount">结算金额：¥{{item.settlementInfo.amount}}</text>
          <text class="settlement-status {{item.settlementInfo.status === 'confirmed' ? 'confirmed' : 'pending'}}">
            {{item.settlementInfo.status === 'confirmed' ? '已确认' : '待处理'}}
          </text>
        </view>
        <view class="room-desc alert">点击处理此结算申请</view>
        <view class="room-arrow">›</view>
      </view>
    </block>
  </view>
</view>
