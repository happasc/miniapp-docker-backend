.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0b0320 0%, #1a0a3e 100%);
  box-sizing: border-box;
  padding-top: 120rpx; /* 为导航栏留出空间 */
}

.tab-header {
  display: flex;
  background: linear-gradient(180deg, rgba(43, 11, 89, 0.95), rgba(59, 15, 102, 0.9));
  border-bottom: 1rpx solid rgba(139, 92, 246, 0.3);
  position: sticky;
  top: 120rpx; /* 与容器padding-top一致 */
  z-index: 100;
  backdrop-filter: blur(10px);
  padding: 16rpx 32rpx;
  box-sizing: border-box;
  margin: 0 24rpx;
  border-radius: 16rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 30rpx;
  color: rgba(230, 217, 255, 0.7);
  position: relative;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  color: #ffd6ff;
  font-weight: bold;
  background: rgba(139, 92, 246, 0.15);
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #c084fc, #7c3aed);
  border-radius: 4rpx;
  box-shadow: 0 0 12rpx rgba(192, 132, 252, 0.6);
}

.list-container {
  padding: 24rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.empty-tip {
  text-align: center;
  color: rgba(230, 217, 255, 0.5);
  font-size: 28rpx;
  margin-top: 200rpx;
}

.room-card {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.01));
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(11, 3, 32, 0.4);
  position: relative;
  border: 1rpx solid rgba(139, 92, 246, 0.15);
}

.room-card:active {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02));
  transform: scale(0.98);
}

.room-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.user-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 2rpx solid rgba(139, 92, 246, 0.3);
}

.user-avatar-placeholder {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: bold;
  margin-right: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.user-avatar-placeholder.refund-icon {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  font-size: 34rpx;
  box-shadow: 0 4rpx 12rpx rgba(245, 87, 108, 0.3);
}

/* ✨ 新增：结算图标样式 */
.user-avatar-placeholder.settlement-icon {
  background: linear-gradient(135deg, #7c3aed 0%, #6b21a8 100%);
  font-size: 34rpx;
  box-shadow: 0 4rpx 12rpx rgba(124, 58, 237, 0.3);
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffd6ff;
  max-width: 400rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.room-time {
  font-size: 24rpx;
  color: rgba(217, 207, 255, 0.6);
  flex-shrink: 0;
}

.room-desc {
  font-size: 28rpx;
  color: rgba(230, 217, 255, 0.8);
  line-height: 1.6;
  margin-right: 40rpx;
}

.room-desc.alert {
  color: #fbbf24;
  font-weight: bold;
}

/* ✨ 退款信息样式 */
.refund-order-no {
  display: block;
  color: rgba(230, 217, 255, 0.9);
  font-size: 26rpx;
  margin-bottom: 8rpx;
}

.refund-amount {
  display: block;
  color: #fbbf24;
  font-size: 28rpx;
  font-weight: bold;
}

/* ✨ 新增：结算信息样式 */
.settlement-amount {
  display: block;
  color: #eabb55;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.settlement-status {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.settlement-status.pending {
  background: rgba(251, 191, 36, 0.15);
  color: #fbbf24;
}

.settlement-status.confirmed {
  background: rgba(16, 185, 129, 0.15);
  color: #10b981;
}

.room-arrow {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 48rpx;
  color: rgba(139, 92, 246, 0.4);
  font-weight: 300;
}
