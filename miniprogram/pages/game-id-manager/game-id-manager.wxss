page {
  background-color: #1a1b2e;
  height: 100vh;
}

.container {
  padding: 40rpx 30rpx;
}

.intro-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.game-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.game-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 30rpx;
  border: 1px solid rgba(255, 255, 255, 0.05);
}

.game-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.game-title {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

.game-input-container {
  display: flex;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 12rpx;
  padding: 10rpx 20rpx;
  border: 1rpx solid rgba(139, 92, 246, 0.3);
  align-items: center;
}

.id-input {
  flex: 1;
  height: 70rpx;
  color: #fff;
  font-size: 28rpx;
  padding-left: 10rpx;
}

.save-btn {
  margin-left: 20rpx;
  color: #8b5cf6;
  font-size: 28rpx;
  font-weight: bold;
  padding: 10rpx 20rpx;
}

.save-btn:active {
  opacity: 0.7;
}

.footer-btn {
  margin-top: 60rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(90deg, #8b5cf6, #6b21a8);
  color: #fff;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 10rpx 20rpx rgba(139, 92, 246, 0.3);
}