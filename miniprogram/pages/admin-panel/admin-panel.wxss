/* pages/admin-panel/admin-panel.wxss */
page {
  background-color: #1a1b2e;
  color: #fff;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

.content {
  flex: 1;
  padding: 0 20rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* 顶部数据看板 */
.dashboard {
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 30rpx 0;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.dash-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.dash-num {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.dash-num.waiting { color: #ffcc00; }
.dash-num.processing { color: #00ffcc; }
.dash-num.total { color: #fff; }

.dash-label {
  font-size: 24rpx;
  color: #aaa;
}

/* 选项卡 */
.tabs {
  display: flex;
  margin-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #888;
  position: relative;
  transition: all 0.3s ease;
}

.tab-item.active {
  color: #00ffcc;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #00ffcc;
  border-radius: 4rpx;
}

/* 工单列表 */
.order-list {
  flex: 1;
  height: calc(100vh - 350rpx); /* 粗略估算高度 */
}

.order-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.card-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
  border-bottom: 1rpx dashed rgba(255, 255, 255, 0.2);
  padding-bottom: 16rpx;
}

.order-id {
  font-size: 24rpx;
  color: #aaa;
}

.order-time {
  font-size: 22rpx;
  color: #888;
}

.card-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.game-info {
  display: flex;
  flex-direction: column;
}

.game-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.service-name {
  font-size: 26rpx;
  color: #00ffcc;
}

.price-info {
  text-align: right;
}

.price-info .label {
  font-size: 24rpx;
  color: #aaa;
}

.price-info .amount {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff0055; /* 紫红色点缀 */
}

.card-footer {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  align-items: center;
}

.btn {
  margin: 0;
  font-size: 24rpx;
  border-radius: 30rpx;
  padding: 12rpx 24rpx;
  line-height: 1.5;
  border: none;
}

.btn-primary {
  background-color: #00ffcc;
  color: #1a1b2e;
  font-weight: bold;
}

.btn-danger {
  background-color: transparent;
  color: #ff4444;
  border: 1rpx solid #ff4444;
}

.btn-warning {
  background-color: #ff9500;
  color: #fff;
  font-weight: bold;
}

.btn-success {
  background-color: #00cc66;
  color: #fff;
  font-weight: bold;
}

.status-text {
  font-size: 26rpx;
  font-weight: bold;
}
.text-processing { color: #00ffcc; }
.text-finished { color: #ffcc00; }
.text-completed { color: #888; }


.empty-state {
  text-align: center;
  color: #666;
  font-size: 28rpx;
  margin-top: 100rpx;
}
